<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.djtools.user.RefreshTokenMapper">

    <resultMap id="RefreshTokenResultMap" type="com.djtools.user.RefreshTokenRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="token" column="token"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="revoked" column="revoked"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.djtools.user.RefreshTokenRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refresh_token (user_id, token, expires_at, revoked)
        VALUES (#{userId}, #{token}, #{expiresAt}, #{revoked})
    </insert>

    <select id="findActiveByToken" resultMap="RefreshTokenResultMap">
        SELECT *
        FROM refresh_token
        WHERE token = #{token}
          AND revoked = FALSE
          AND expires_at &gt; CURRENT_TIMESTAMP
    </select>

    <update id="revokeByToken">
        UPDATE refresh_token
        SET revoked = TRUE
        WHERE token = #{token}
    </update>

    <update id="revokeByUserId">
        UPDATE refresh_token
        SET revoked = TRUE
        WHERE user_id = #{userId}
    </update>

    <update id="revokeExpired">
        UPDATE refresh_token
        SET revoked = TRUE
        WHERE expires_at &lt;= #{now}
    </update>
</mapper>
