# 镜像配置
GITHUB_REPOSITORY_OWNER=shendongjuns
IMAGE_TAG=latest

# 对外端口
WEB_PORT=8088

# 是否开启后端 CORS 校验；Nginx 同源代理部署建议关闭，前后端跨域部署时改为 true
CORS_ENABLED=false

# Web 地址指定，开启 CORS 校验时需与浏览器访问来源完全一致
WEB_ORIGIN=http://localhost:8088

# PostgreSQL
POSTGRES_DB=dj_tools
POSTGRES_USER=djtools
POSTGRES_PASSWORD=change-this-postgres-password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=dj-tools-attachments

# JWT 密钥，生产环境必须替换为足够长的随机字符串
JWT_SECRET=change-this-jwt-secret-to-a-long-random-string
